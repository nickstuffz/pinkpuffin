---
import BaseLayout from "../layouts/BaseLayout.astro";
import ColumnLayout from "../layouts/ColumnLayout.astro";
import { getEntry } from "astro:content";

const events = await getEntry("markdown", "events");
const { Content } = await events.render();
---

<BaseLayout
  pageTitle={events.data.title}
  pageDescription={events.data.description}
>
  <ColumnLayout pageData={events}>
    <Content />
  </ColumnLayout>
</BaseLayout>
